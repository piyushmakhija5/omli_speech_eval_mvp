# Copy to .env and fill in real values. .env is gitignored.

# Sarvam AI Speech-to-Text — required for the speech-delay pipeline's
# ASR-dependent metrics (word_coverage, naming_accuracy, speaking_rate).
# Get a key at https://sarvam.ai/. Without it, those metrics stay
# computed=false and the pipeline falls back to the 5 pure-audio metrics.
SARVAM_API_KEY=

# Endpoint and request defaults — these match Omli production.
SARVAM_STT_URL=https://api.sarvam.ai/speech-to-text
SARVAM_STT_LANGUAGE_CODE=hi-IN
SARVAM_STT_MODEL=saaras:v3
SARVAM_STT_MODE=codemix

# Whisper secondary ASR — DEFERRED for the MVP. Currently the backend ships
# Sarvam-only (see backend/asr.py module docstring for the Whisper-fallback
# insertion point and rationale). This flag exists for forward compatibility.
ENABLE_WHISPER_DISFLUENCY=false
